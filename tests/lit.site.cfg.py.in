# This file is configured by CMake from lit.site.cfg.py.in. It records the
# build-specific tool locations and then loads the main lit.cfg.py.

config.spirv2clc_tool = r"@SPIRV2CLC_TOOL@"
config.clang_executable = r"@CLANG_EXECUTABLE@"
config.filecheck_executable = r"@FILECHECK_EXECUTABLE@"
config.spirv2clc_test_exec_root = r"@CMAKE_CURRENT_BINARY_DIR@"

lit_config.load_config(config, r"@CMAKE_CURRENT_SOURCE_DIR@/lit.cfg.py")
