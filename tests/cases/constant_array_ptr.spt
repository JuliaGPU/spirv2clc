; RUN: %spirv2clc --asm %s | %clang -c -cl-std=CL1.2 -x cl - -o /dev/null
; RUN: %spirv2clc --asm %s | %FileCheck %s
; A non-string UniformConstant array used as a pointer (bitcast + load). The
; variable's SPIR-V id is a pointer, but OpenCL 1.2 forbids program-scope
; pointer variables, so references must take the address of the stored value.
               OpCapability Kernel
               OpCapability Addresses
               OpCapability Int8
               OpCapability Linkage
               OpMemoryModel Physical64 OpenCL
       %void = OpTypeVoid
       %uint = OpTypeInt 32 0
      %uchar = OpTypeInt 8 0
     %uint_2 = OpConstant %uint 2
         %c0 = OpConstant %uint 10
         %c1 = OpConstant %uint 20
        %arr = OpTypeArray %uint %uint_2
       %comp = OpConstantComposite %arr %c0 %c1
     %pconst = OpTypePointer UniformConstant %arr
          %g = OpVariable %pconst UniformConstant %comp
     %puchar = OpTypePointer UniformConstant %uchar
       %fnty = OpTypeFunction %void
         %fn = OpFunction %void None %fnty
        %lbl = OpLabel
          %p = OpBitcast %puchar %g
          %v = OpLoad %uchar %p
               OpReturn
               OpFunctionEnd
; CHECK: constant arr{{[0-9]+}} {{.*}}_storage =
; CHECK: (uchar constant*)(&
