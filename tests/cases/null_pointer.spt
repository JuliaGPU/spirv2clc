; RUN: %spirv2clc --asm %s | %clang -c -cl-std=CL1.2 -x cl - -o /dev/null
; OpConstantNull / OpUndef of a pointer type used to hit UNIMPLEMENTED.
               OpCapability Kernel
               OpCapability Addresses
               OpCapability Linkage
               OpMemoryModel Physical64 OpenCL
       %void = OpTypeVoid
       %uint = OpTypeInt 32 0
        %pgf = OpTypePointer CrossWorkgroup %uint
       %null = OpConstantNull %pgf
       %fnty = OpTypeFunction %void
         %fn = OpFunction %void None %fnty
        %lbl = OpLabel
          %v = OpCopyObject %pgf %null
               OpReturn
               OpFunctionEnd
