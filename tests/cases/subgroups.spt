; The Groups capability (sub-group / work-group collectives) maps to the
; cl_khr_subgroups extension, which is available from OpenCL C 2.0 on:
; translation must fail below that, and otherwise enable it via pragma like the
; fp16/fp64 extensions.
; RUN: not %spirv2clc --asm --spirv-version=1.4 --cl-std=CL1.2 %s
; RUN: %spirv2clc --asm --spirv-version=1.4 --cl-std=CL3.0 %s | %FileCheck %s
               OpCapability Kernel
               OpCapability Addresses
               OpCapability Groups
               OpMemoryModel Physical64 OpenCL
               OpEntryPoint Kernel %main "test"
       %void = OpTypeVoid
     %mainty = OpTypeFunction %void
       %main = OpFunction %void None %mainty
        %mbb = OpLabel
               OpReturn
               OpFunctionEnd
; CHECK: #pragma OPENCL EXTENSION cl_khr_subgroups : enable
