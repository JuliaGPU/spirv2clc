; vloadn / vstoren transfer N elements between a scalar pointer and a vecN; the
; element count comes from the literal (load) or the value's vector width (store).
; RUN: %spirv2clc --asm %s | %clang -c -cl-std=CL1.2 -x cl - -o /dev/null
; RUN: %spirv2clc --asm %s | %FileCheck %s
               OpCapability Kernel
               OpCapability Addresses
               OpCapability Int64
        %ext = OpExtInstImport "OpenCL.std"
               OpMemoryModel Physical64 OpenCL
               OpEntryPoint Kernel %k "test"
       %void = OpTypeVoid
        %f32 = OpTypeFloat 32
        %i64 = OpTypeInt 64 0
        %v4f = OpTypeVector %f32 4
    %p_g_f32 = OpTypePointer CrossWorkgroup %f32
        %off = OpConstant %i64 0
       %fnty = OpTypeFunction %void %p_g_f32 %p_g_f32
          %k = OpFunction %void None %fnty
        %src = OpFunctionParameter %p_g_f32
        %dst = OpFunctionParameter %p_g_f32
        %lbl = OpLabel
          %v = OpExtInst %v4f %ext vloadn %off %src 4
         %st = OpExtInst %void %ext vstoren %v %off %dst
               OpReturn
               OpFunctionEnd
; CHECK: = vload4(((ulong)0), {{v[0-9]+}});
; CHECK: vstore4({{v[0-9]+}}, ((ulong)0), {{v[0-9]+}});
