; OpFRem takes the sign of operand 1 (the dividend), which is exactly fmod().
; OpFMod takes the sign of operand 2 (the divisor) -- the floored modulo
; "a - b*floor(a/b)" -- which differs from fmod() whenever the operands have
; opposite signs. They must not both translate to fmod().
; RUN: %spirv2clc --asm %s | %clang -c -cl-std=CL1.2 -x cl - -o /dev/null
; RUN: %spirv2clc --asm %s | %FileCheck %s
               OpCapability Kernel
               OpCapability Addresses
               OpCapability Linkage
               OpMemoryModel Physical64 OpenCL
       %void = OpTypeVoid
        %f32 = OpTypeFloat 32
      %p_g_f = OpTypePointer CrossWorkgroup %f32
       %fnty = OpTypeFunction %void %f32 %f32 %p_g_f
         %fn = OpFunction %void None %fnty
          %a = OpFunctionParameter %f32
          %b = OpFunctionParameter %f32
        %out = OpFunctionParameter %p_g_f
        %lbl = OpLabel
        %mod = OpFMod %f32 %a %b
        %rem = OpFRem %f32 %a %b
        %sum = OpFAdd %f32 %mod %rem
               OpStore %out %sum
               OpReturn
               OpFunctionEnd
; OpFMod -> floored modulo (sign of divisor)
; CHECK: = {{v[0-9]+}} - {{v[0-9]+}} * floor({{v[0-9]+}} / {{v[0-9]+}});
; OpFRem -> fmod (sign of dividend)
; CHECK: = fmod({{v[0-9]+}}, {{v[0-9]+}});
