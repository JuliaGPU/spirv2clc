; A scalar built-in load emits no declaration (it renders inline as its query),
; so when codegen also gives the load result a name it must still render as the
; builtin call, not the bare name -- otherwise the name is an undeclared use.
; RUN: %spirv2clc --asm --spirv-version=1.4 --cl-std=CL2.0 %s | %FileCheck %s
; RUN: %spirv2clc --asm --spirv-version=1.4 --cl-std=CL2.0 %s | %clang -c -cl-std=CL2.0 -x cl - -o /dev/null
               OpCapability Kernel
               OpCapability Addresses
               OpCapability SubgroupDispatch
               OpMemoryModel Physical64 OpenCL
               OpEntryPoint Kernel %k "test" %sgid
               OpName %val "val.i4"
               OpDecorate %sgid BuiltIn SubgroupId
       %void = OpTypeVoid
       %uint = OpTypeInt 32 0
  %p_in_uint = OpTypePointer Input %uint
   %p_g_uint = OpTypePointer CrossWorkgroup %uint
       %sgid = OpVariable %p_in_uint Input
       %fnty = OpTypeFunction %void %p_g_uint
          %k = OpFunction %void None %fnty
        %out = OpFunctionParameter %p_g_uint
        %lbl = OpLabel
        %val = OpLoad %uint %sgid
               OpStore %out %val
               OpReturn
               OpFunctionEnd
; CHECK: get_sub_group_id()
; CHECK-NOT: val_i4
