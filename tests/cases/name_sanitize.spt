; RUN: %spirv2clc --asm %s | %clang -c -cl-std=CL1.2 -x cl - -o /dev/null
; RUN: %spirv2clc --asm %s | %FileCheck %s
; OpNames carrying characters invalid in C identifiers (e.g. Julia's
; "a::CLDeviceArray") must be sanitized, not emitted verbatim.
               OpCapability Kernel
               OpCapability Addresses
               OpCapability Linkage
               OpName %param "a::CLDeviceArray"
               OpMemoryModel Physical64 OpenCL
       %void = OpTypeVoid
       %uint = OpTypeInt 32 0
       %puint = OpTypePointer CrossWorkgroup %uint
       %fnty = OpTypeFunction %void %puint
         %fn = OpFunction %void None %fnty
      %param = OpFunctionParameter %puint
        %lbl = OpLabel
               OpReturn
               OpFunctionEnd
; CHECK: a__CLDeviceArray
