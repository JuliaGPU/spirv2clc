; OpControlBarrier fence flags come from the memory semantics, not the memory
; scope, and any combination is valid -- including Workgroup | CrossWorkgroup
; (0x310 = 784), the common barrier(CLK_LOCAL_MEM_FENCE | CLK_GLOBAL_MEM_FENCE).
; RUN: %spirv2clc --asm %s | %clang -c -cl-std=CL1.2 -x cl - -o /dev/null
; RUN: %spirv2clc --asm %s | %FileCheck %s
               OpCapability Kernel
               OpCapability Addresses
               OpMemoryModel Physical64 OpenCL
               OpEntryPoint Kernel %k "test"
       %void = OpTypeVoid
       %uint = OpTypeInt 32 0
         %wg = OpConstant %uint 2
        %sem = OpConstant %uint 784
       %fnty = OpTypeFunction %void
          %k = OpFunction %void None %fnty
        %lbl = OpLabel
               OpControlBarrier %wg %wg %sem
               OpReturn
               OpFunctionEnd
; CHECK: barrier(CLK_LOCAL_MEM_FENCE | CLK_GLOBAL_MEM_FENCE)
